outMode=carousel&cardType=standard&baseProduct=40497395","header":"Verwante producten","attributionLabel":"rec-pip-similar-products"},"recommendedForYou":{"src":"/be/nl/listing/fragments/product-rec/recommended-for-you/?layoutMode=carousel&cardType=standard&baseProduct=40497395","header":"Aanbevolen voor jou","attributionLabel":"rec-pip-recommended-for-you"},"moreFrom":{"src":"/be/nl/listing/fragments/product-rec/more-from/?layoutMode=carousel&cardType=standard&baseProduct=40497395","header":"Meer uit de ","attributionLabel":"rec-pip-more-from"},"accessories":{"src":"/be/nl/listing/fragments/product-rec/accessories/?layoutMode=carousel&cardType=standard&baseProduct=40497395","header":"Accessoires voor ORMANÄS","attributionLabel":"rec-pip-accessories"}},"productInformationSectionProps":{"productDetailsProps":{"accordionObject":{"goodToKnow":{"id":"product-details-good-to-know","title":"Goed om te weten.","contentProps":{"goodToKnow":[{"name":"May be completed","text":"Dit product maakt deel uit van ons assortiment voor een slim huis. Verbind het (samen met andere slimme producten) met de DIRIGERA hub en de IKEA Home smart app voor meer functies en mogelijkheden."},{"name":"Purchase-/Other information","text":"Gebruik ook de afstandsbediening om je lichtbron te bedienen."},{"name":"Purchase-/Other information","text":"De led-lichtbron is geïntegreerd."},{"name":"Purchase-/Other information","text":"Download de app IKEA Home smart gratis via Google Play of de App Store, afhankelijk van de telefoon of tablet die je hebt."},{"name":"Compl. assembly information","text":"Kan op de gewenste afmeting worden gesneden."},{"name":"Compl. assembly information","text":"Dit slimme product kan niet worden verbonden met een TRÅDFRI hub."},{"name":"Sold separately","text":"De afstandsbediening wordt apart verkocht."},{"name":"Sold separately","text":"Verbindingshub wordt apart verkocht."},{"name":"Functions (other)","text":"Om gebruik te kunnen maken van een stemassistent, kan je verbinding maken met Amazon Alexa, de Woning-app van Apple of Google Home door integratie met de IKEA Home smart app."},{"name":"Other information","text":"IKEA of Sweden AB SE-343 81 Älmhult, IKEA.com"}]}},"materialsAndCare":{"id":"product-details-material-and-care","title":"Materialen en onderhoud","contentProps":{"materials":[{"materials":[{"material":"polycarbonaat","part":"Omhulsel:"},{"material":"Urethaan (kunststof)","part":"Afdeklijst:"},{"material":"versterkte polyamide","part":"Snoerklem:"}]}],"materialsAndCareLinks":[],"careInstructions":[{"texts":["Afnemen met een doekje met wat mild schoonmaakmiddel.","Nadrogen met een droge doek."]}],"proposition65":[],"detailsMaterialText":"Materiaal","detailsCareText":"Onderhoud","ariaOpensInNewTabLabel":"{text} (opent in een nieuw tabblad)","warningText":"Waarschuwing"}},"safetyAndCompliance":{"id":"product-details-safety-and-compliance","title":"Veiligheid en naleving","contentProps":{"safetyAndCompliance":[{"name":"Safety information","text":"Alleen voor gebruik binnenshuis."},{"name":"Test results and compliance","text":"Dit product is voorzien van de CE-markering"}],"safetyAndComplianceLinks":[],"ariaOpensInNewTabLabel":"{text} (opent in een nieuw tabblad)"}},"assemblyAndDocuments":{"id":"product-details-assembly-and-documents","title":"Montage en documenten","contentProps":{"ariaOpensInNewTabLabel":"{text} (opent in een nieuw tabblad)","assemblyVideos":[],"attachments":{"assembly":{"header":"Montage‑instructies","attachments":[{"id":"404.973.95","url":"https://www.ikea.com/be/nl/assembly_instructions/ormanaes-led-strip-smart-draadloos-dimbaar-gekleurd-en-wit-spectrum__AA-2364567-5-2.pdf","label":"ORMANÄS Led-strip"}]},"software":{"header":"Software","attachments":[]},"declaration":{"header":"Conformiteitsverklaring","attachments":[{"id":"404.973.95","url":"https://www.ikea.com/be/nl/dec_of_conformity/ormanaes-led-strip-smart-draadloos-dimbaar-gekleurd-en-wit-spectrum__AA-2495809-3-1.pdf","label":"ORMANÄS Led-strip"},{"id":"404.973.95","url":"https://www.ikea.com/be/nl/dec_of_conformity/ormanaes-led-strip-smart-draadloos-dimbaar-gekleurd-en-wit-spectrum__AA-2641808-2-1.pdf","label":"ORMANÄS Led-strip"}]},"other":{"header":"Andere documenten","attachments":[]},"customerDisassembly":{"header":"Demontage-instructies","attachments":[]},"professionalDisassembly":{"header":"Demontage en recyclage (voor industrieprofessionals)","attachments":[]},"manual":{"header":"Advies en verzorgingsinstructies","attachments":[{"id":"404.973.95","url":"https://www.ikea.com/be/nl/manuals/ormanaes-led-strip-smart-draadloos-dimbaar-gekleurd-en-wit-spectrum__AA-2407682-3-2.pdf","label":"ORMANÄS Led-strip"}]}}}}},"articleNumberLabel":"Artikelnummer","productDescriptionProps":{"paragraphs":["Het licht van deze LED-verlichtingsstrip creëert een gezellige sfeer, waar je hem ook neerzet.","De led-verlichtingsstrip is buigbaar zodat je deze heel eenvoudig achter de tv of een boekenkast kan bevestigen.","Je kan de verlichtingsstrip heel makkelijk korter maken door deze te knippen op de plekken die zijn gemarkeerd met een klein schaarsymbool.","Gemakkelijk te bevestigen - verwijder gewoon het papier van de zelfklevende tape en plak de verlichtingsstrip waar je hem wil hebben.","Je kan de stemming in de kamer snel en gemakkelijk veranderen door de verlichting te dimmen en de kleur van de verlichting te wijzigen.","De verlichtingsstrip wordt geleverd met een driver die je kan aansluiten op een stopcontact."],"designerLabel":"Designer","designerName":"IKEA of Sweden"},"productId":"40497395","title":"Productdetails"},"measurementsProps":{"chooseDifferentSizeLinkText":"Kies een andere maat","eventLabel":"pip_measurements","fallbackImage":{"alt":"ORMANÄS opgerolde led-lamp","height":2000,"id":"1209372_PE909169","imageFileName":"1209372_PE909169_S5.JPG","orientation":"square","type":"MAIN_PRODUCT_IMAGE","url":"https://www.ikea.com/be/nl/images/products/ormanaes-led-strip-smart-draadloos-dimbaar-gekleurd-en-wit-spec